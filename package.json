{
  "name": "untis-api",
  "version": "1.0.0",
  "description": "A TypeScript library for the Untis API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --keep-names",
    "dev": "ts-node src/index.ts",
    "test": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit"
  },
  "author": "Fabian Oppermann",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "20.10.5",
    "@typescript-eslint/eslint-plugin": "6.15.0",
    "@typescript-eslint/parser": "6.15.0",
    "eslint": "8.56.0",
    "prettier": "3.1.1",
    "ts-node": "10.9.2",
    "tsup": "8.0.1",
    "typescript": "5.3.3",
    "vitest": "1.0.4"
  },
  "dependencies": {
    "zod": "3.22.4"
  },
  "publishConfig": {
    "access": "public"
  }
}