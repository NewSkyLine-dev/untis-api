{
  "name": "untis-api",
  "version": "1.0.0",
  "description": "A TypeScript library for the Untis API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --keep-names",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit"
  },
  "author": "Fabian Oppermann",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "22.13.1",
    "ts-node": "10.9.2",
    "tsup": "8.3.6",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "axios": "1.7.9",
    "i": "0.3.7",
    "moment": "2.30.1",
    "npm": "11.1.0",
    "zod": "3.24.1"
  },
  "publishConfig": {
    "access": "public"
  }
}